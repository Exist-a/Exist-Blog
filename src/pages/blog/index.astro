---
import BlogLayout from '../../layouts/BlogLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { allPostSummaries, postsSortedDesc } from '../../data/posts';

const posts = postsSortedDesc(await allPostSummaries());
---

<BlogLayout
  title="笔记 · Exist"
  description="Exist 的全部笔记。"
  eyebrow="all · 2026"
  pageTitle="全部笔记"
  count={posts.length}
  pageDescription="全部笔记，按时间倒序。"
>
  <ul class="post-list">
    {posts.map(post => (
      <li>
        <PostCard
          post={post}
          href={`/blog/${post.category}/${post.slug}/`}
        />
      </li>
    ))}
  </ul>
</BlogLayout>

<style>
  .post-list { list-style: none; margin: 0; padding: 0; }
</style>