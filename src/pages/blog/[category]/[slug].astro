---
import BlogLayout from '../../../layouts/BlogLayout.astro';
import Comments from '../../../components/Comments.astro';
import {
  categories,
  allPosts,
  getCategory,
  getSubcategory,
  type CategorySlug,
  type Post,
} from '../../../data/posts';

export async function getStaticPaths() {
  return categories.flatMap(cat =>
    allPosts
      .filter(p => p.category === cat.slug)
      .map(post => ({
        params: { category: cat.slug, slug: post.slug },
        props: { post, category: cat.slug },
      }))
  );
}

interface PageProps {
  post: Post;
  category: CategorySlug;
}
const { post, category } = Astro.props as PageProps;
const cat = getCategory(category)!;
const sub = post.tags[0] ? getSubcategory(post.tags[0]) : undefined;

const date = new Date(post.date);
const formatted = `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, '0')}.${String(date.getDate()).padStart(2, '0')}`;
---

<BlogLayout
  title={`${post.title} · Exist`}
  description={post.excerpt}
  eyebrow={`${cat.label}${sub ? ` · ${sub.label}` : ''} · ${formatted}`}
  pageTitle={post.title}
  category={category}
  activeTag={post.tags[0]}
>
  <article class="post">
    <p class="post__excerpt lead">{post.excerpt}</p>
    <hr class="rule" />

    <div class="post__body">
      {post.body ? (
        <div class="post__content" set:html={post.body} />
      ) : (
        <>
          <p class="post__placeholder muted">
            本文正文待补充。
          </p>
        </>
      )}
    </div>

    <p class="post__back">
      <a href={`/blog/${category}/`}>← 返回 {cat.label}</a>
    </p>
  </article>

  <Comments />
</BlogLayout>

<style>
  .post__excerpt {
    margin-bottom: 1.5rem;
  }
  .post__body {
    margin: 2rem 0;
  }
  .post__placeholder {
    color: var(--text-soft);
    line-height: 1.7;
    margin: 0 0 0.75rem 0;
  }

  /* ── 文章正文排版 ── */
  .post__content { color: var(--text); line-height: 1.75; }
  .post__content > * + * { margin-top: 1.25rem; }
  .post__content p { color: var(--text-soft); }
  .post__content h2 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.375rem;
    letter-spacing: -0.015em;
    color: var(--text);
    margin-top: 2.5rem !important;
    padding-top: 1.5rem;
    border-top: 1px solid var(--ink-line);
  }
  .post__content h2:first-child { border-top: 0; padding-top: 0; }
  .post__content strong { color: var(--text); font-weight: 600; }
  .post__content code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    color: var(--accent);
    background: var(--ink-soft);
    padding: 0.1em 0.4em;
    border-radius: 2px;
  }
  .post__content pre {
    margin: 1.5rem 0;
    padding: 1rem 1.25rem;
    background: var(--ink-soft);
    border: 1px solid var(--ink-line);
    border-radius: 4px;
    overflow-x: auto;
    font-size: 0.8125rem;
    line-height: 1.6;
  }
  .post__content pre code {
    background: transparent;
    padding: 0;
    color: var(--text);
    font-size: inherit;
  }
  .post__content ol,
  .post__content ul {
    margin: 1rem 0;
    padding-left: 1.5rem;
    color: var(--text-soft);
  }
  .post__content ol li,
  .post__content ul li { margin: 0.5rem 0; line-height: 1.7; }
  .post__content ol li::marker { color: var(--accent); font-family: var(--font-mono); }

  .post__back {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--ink-line);
    font-size: 0.9375rem;
  }
  .post__back a { color: var(--accent); }
</style>