---
import BlogLayout from '../../../layouts/BlogLayout.astro';
import Comments from '../../../components/Comments.astro';
import { getCollection, render } from 'astro:content';
import {
  categories,
  getCategory,
  getSubcategory,
  type CategorySlug,
} from '../../../data/posts';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return categories.flatMap(cat =>
    posts
      .filter(p => p.data.category === cat.slug)
      .map(post => ({
        params: {
          category: cat.slug,
          slug: post.id.split('/').pop()!.replace(/\.md$/, ''),
        },
        props: { post, category: cat.slug },
      }))
  );
}

interface PageProps {
  post: Awaited<ReturnType<typeof getCollection<'posts'>>>[number];
  category: CategorySlug;
}
const { post, category } = Astro.props as PageProps;
const cat = getCategory(category)!;
const sub = post.data.tags[0] ? getSubcategory(post.data.tags[0]) : undefined;

const formatted = `${post.data.date.getFullYear()}.${String(post.data.date.getMonth() + 1).padStart(2, '0')}.${String(post.data.date.getDate()).padStart(2, '0')}`;

const { Content } = await render(post);
const BASE = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');
---

<BlogLayout
  title={`${post.data.title} · Exist`}
  description={post.data.excerpt}
  eyebrow={`${cat.label}${sub ? ` · ${sub.label}` : ''} · ${formatted}`}
  pageTitle={post.data.title}
  category={category}
  activeTag={post.data.tags[0]}
>
  <article class="post">
    <p class="post__excerpt lead">{post.data.excerpt}</p>
    <hr class="rule" />

    <div class="post__body">
      <div class="post__content">
        <Content />
      </div>
    </div>

    <p class="post__back">
      <a href={`${BASE}blog/${category}/`}>← 返回 {cat.label}</a>
    </p>
  </article>

  <Comments />
</BlogLayout>

<style is:global>
  /* 文章页专属：标题小一号 + 正文撑满侧栏外剩余空间 */
  .blog-layout__main { max-width: none !important; }
  .page-header__title {
    font-size: clamp(1.4rem, 2.4vw, 1.85rem) !important;
    line-height: 1.3;
    letter-spacing: -0.015em;
    font-family: var(--font-body) !important;
    font-weight: 600;
  }

  /* Content Collections 渲染出来的 Markdown 节点是 children，需要走全局作用域 */
  .post__content {
    color: var(--text);
    line-height: 1.75;
    width: 100%;
  }
  /* 所有子元素撑满父容器宽度 */
  .post__content > * { max-width: 100%; }
  .post__content > * + * { margin-top: 1.25rem; }
  .post__content p { color: var(--text-soft); font-size: 1rem; line-height: 1.85; }
  .post__content h2 {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1.25rem;
    letter-spacing: -0.005em;
    color: var(--text);
    margin-top: 2.5rem !important;
    padding-top: 1.5rem;
    border-top: 1px solid var(--ink-line);
  }
  .post__content h2:first-child { border-top: 0; padding-top: 0; }
  .post__content h3 {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1.0625rem;
    color: var(--text);
    margin-top: 2rem !important;
  }
  .post__content strong { color: var(--text); font-weight: 600; }
  .post__content code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    color: var(--accent);
    background: var(--ink-soft);
    padding: 0.1em 0.4em;
    border-radius: 2px;
  }
  .post__content pre {
    margin: 1.5rem 0;
    padding: 1rem 1.25rem;
    background: var(--ink-soft);
    border: 1px solid var(--ink-line);
    border-radius: 4px;
    overflow-x: auto;
    font-size: 0.8125rem;
    line-height: 1.6;
  }
  .post__content pre code {
    background: transparent;
    padding: 0;
    color: var(--text);
    font-size: inherit;
  }
  .post__content ol,
  .post__content ul {
    margin: 1rem 0;
    padding-left: 1.5rem;
    color: var(--text-soft);
  }
  .post__content ol li,
  .post__content ul li { margin: 0.5rem 0; line-height: 1.7; }
  .post__content ol li::marker { color: var(--accent); font-family: var(--font-mono); }
  .post__content img {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 1.5rem auto;
    border-radius: 4px;
  }
  .post__content a { color: var(--accent); }

  .post__excerpt {
    margin-bottom: 1.5rem;
  }
  .post__body {
    margin: 2rem 0;
  }
  .post__back {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--ink-line);
    font-size: 0.9375rem;
  }
  .post__back a { color: var(--accent); }
</style>