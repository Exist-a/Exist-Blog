---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
---

<BaseLayout title="关于作者 · Exist" description="关于 Exist —— 个人学习笔记，记录学习心得。">
  <div class="about">
    <PageHeader
      eyebrow="about"
      title="关于作者"
    />

    <section class="about__intro">
      <img
        src="/avatar.jpg"
        alt="Exist 头像"
        class="about__avatar"
        width="140"
        height="140"
        loading="lazy"
      />
      <div class="about__intro-text">
        <p class="about__hello">我是 <strong>Exist</strong>，目前就读于<span class="hl">哈尔滨理工大学</span>。</p>
        <p>这是我的个人学习笔记，记录着我的学习心得。</p>
      </div>
    </section>

    <section class="about__section">
      <h2 class="about__h2">目前的个人全栈项目</h2>
      <a
        href="https://decisioncourt.cn"
        target="_blank"
        rel="noopener"
        class="project"
      >
        <div class="project__head">
          <span class="project__name">决策庭</span>
          <span class="project__url mono">decisioncourt.cn →</span>
        </div>
        <p class="project__desc">
          多 Agent 对抗辩论的 AI 决策辅助工具：围绕跳槽 / 创业 / 投资这类复杂决策，
          让<strong>控方 / 辩方 / 调查员 / 书记员 / 法官</strong>五类专业 Agent 结构化对抗；
          用户可<strong>实时提交证据</strong>供庭审质询，
          最终由法官 Agent 输出一份可审计、可执行的《决策判决书》。
        </p>
        <p class="project__meta mono">
          Next.js 14 · Go + Gin · PostgreSQL · DeepSeek / Kimi · v0.10.4
        </p>
      </a>
    </section>

    <section class="about__section">
      <h2 class="about__h2">联系我</h2>
      <ul class="about__list about__list--contact">
        <li>GitHub：<a href="https://github.com/Exist-a" target="_blank" rel="noopener">@Exist-a</a></li>
        <li>邮箱：<a href="mailto:why.aexist@gmail.com">why.aexist@gmail.com</a></li>
      </ul>
    </section>
  </div>
</BaseLayout>

<style>
  .about {
    width: 100%;
    padding: 2.5rem var(--page-pad-x);
    max-width: none;
  }

  /* ── 顶部：头像 + 简介 左右两栏（窄屏塌成上下） ── */
  .about__intro {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 2.5rem;
    align-items: start;
    margin-bottom: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--ink-line);
  }

  .about__avatar {
    display: block;
    width: 140px;
    height: 140px;
    border-radius: 50%;
    object-fit: cover;
    box-shadow:
      0 0 0 2px var(--avatar-ring),
      0 8px 24px rgba(var(--shadow-color), 0.3);
  }

  .about__intro-text { min-width: 0; }

  .about__hello {
    font-family: var(--font-body);
    font-size: 1.375rem;
    font-weight: 500;
    color: var(--text);
    margin: 0 0 1.25rem 0;
    line-height: 1.4;
  }
  .about__hello strong {
    color: var(--accent);
    font-weight: 600;
  }

  .about p {
    color: var(--text-soft);
    line-height: 1.75;
    margin: 0 0 1rem 0;
  }
  .about p:last-child { margin-bottom: 0; }
  .about .hl { color: var(--accent); }

  /* ── 各小节 ── */
  .about__section {
    margin-bottom: 2.5rem;
  }
  .about__section:last-child { margin-bottom: 0; }

  .about__h2 {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1.0625rem;
    color: var(--text);
    margin: 0 0 1rem 0;
    letter-spacing: -0.005em;
  }

  .about__list {
    list-style: none;
    margin: 0;
    padding: 0;
    color: var(--text-soft);
    line-height: 1.85;
  }
  .about__list li {
    padding: 0.35rem 0;
    border-bottom: 1px solid var(--ink-line);
  }
  .about__list li:last-child { border-bottom: 0; }
  .about__list--contact li { font-size: 0.9375rem; }
  .about__list--contact a { color: var(--accent); }

  /* ── 项目卡 ── */
  .project {
    display: block;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--ink-line);
    border-radius: 4px;
    text-decoration: none;
    color: inherit;
    transition: border-color 160ms ease, transform 160ms ease;
  }
  .project:hover {
    border-color: var(--accent);
    transform: translateX(4px);
  }
  .project__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }
  .project__name {
    font-family: var(--font-body);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text);
  }
  .project:hover .project__name { color: var(--accent); }
  .project__url {
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    color: var(--text-mute);
  }
  .project__desc {
    margin: 0 0 0.75rem 0;
    font-size: 0.9375rem;
    color: var(--text-soft);
    line-height: 1.75;
  }
  .project__desc strong {
    color: var(--text);
    font-weight: 600;
  }
  .project__meta {
    margin: 0;
    padding-top: 0.75rem;
    border-top: 1px solid var(--ink-line);
    font-size: 0.6875rem;
    letter-spacing: 0.05em;
    color: var(--text-mute);
  }

  /* ── 窄屏 ── */
  @media (max-width: 640px) {
    .about__intro {
      grid-template-columns: 96px 1fr;
      gap: 1.5rem;
      margin-bottom: 2rem;
      padding-bottom: 2rem;
    }
    .about__avatar { width: 96px; height: 96px; }
    .about__hello { font-size: 1.125rem; }
  }
</style>