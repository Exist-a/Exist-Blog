---
import '../styles/global.css';
import Nav from '../components/Nav.astro';

const SITE_NAME = 'Exist Blog';
const DEFAULT_TITLE = 'Exist 的 AI 全栈学习笔记';
const DEFAULT_DESCRIPTION =
  'Exist 的个人技术博客，记录前端、后端、数据库、AI 等方向的学习笔记。';
const AUTHOR = 'Exist';
const DEFAULT_OG_IMAGE = 'avatar.jpg'; // 相对于 base path

interface Props {
  title?: string;
  description?: string;
  /** og:type，不传默认 website；文章页传 article */
  ogType?: 'website' | 'article';
  /** 文章发布时间 ISO 字符串（ogType=article 时使用） */
  publishedTime?: string;
  /** 文章分类（如 "前端 / 后端 / 数据库"），仅 article */
  section?: string;
  /** 自定义 og:image 路径（相对 base path），不传用默认头像 */
  ogImage?: string;
}

const {
  title = DEFAULT_TITLE,
  description = DEFAULT_DESCRIPTION,
  ogType = 'website',
  publishedTime,
  section,
  ogImage,
} = Astro.props;

const BASE = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');

// 规范化 URL：去掉末尾斜杠、拼到 site 上
const canonical = new URL(Astro.url.pathname.replace(/\/+$/, '') || '/', Astro.site).toString();

// og:image 必须是绝对 URL。传入值允许是绝对 URL 或相对 base 的路径
const ogImageAbs = ogImage
  ? (ogImage.startsWith('http')
      ? ogImage
      : new URL(BASE.replace(/\/$/, '') + '/' + ogImage.replace(/^\//, ''), Astro.site).toString())
  : new URL(BASE.replace(/\/$/, '') + '/' + DEFAULT_OG_IMAGE, Astro.site).toString();
---

<!DOCTYPE html>
<html lang="zh-Hans">
  <head>
    <meta charset="utf-8" />
    <!-- 网站图标：直接用 /avatar.jpg -->
    <link rel="icon" href={`${BASE}avatar.jpg`} type="image/jpeg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />

    <!-- Canonical：避免被识别为重复内容 -->
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    {ogType === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {ogType === 'article' && section && (
      <meta property="article:section" content={section} />
    )}
    {ogType === 'article' && (
      <meta property="article:author" content={AUTHOR} />
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    <title>{title}</title>

    <!--
      主题初始化：放在 head 顶端，避免刷新时白屏闪一下浅色再切深色
      默认浅色；用户手动选过的写 localStorage('theme')
    -->
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('theme');
          var theme = saved === 'dark' ? 'dark' : 'light';
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
  </head>
  <body>
    <Nav />
    <main class="shell">
      <slot />
    </main>
  </body>
</html>