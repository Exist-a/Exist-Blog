---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import PageHeader from '../components/PageHeader.astro';
import TableOfContents from '../components/TableOfContents.astro';
import {
  getCategory,
  getSubcategory,
  type CategorySlug,
} from '../data/posts';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title?: string;
  description?: string;
  eyebrow?: string;
  pageTitle?: string;
  pageDescription?: string;
  count?: number;
  /** 当前一级分类 → 决定侧栏展示哪些二级目录 */
  category?: CategorySlug;
  /** 当前激活的二级 tag → 其抽屉自动展开 */
  activeTag?: string;
  /** 文章页传入的标题列表，渲染右侧目录 */
  headings?: Heading[];
  /** 透传给 BaseLayout：og:type */
  ogType?: 'website' | 'article';
  /** 透传给 BaseLayout：文章发布时间 ISO 字符串 */
  publishedTime?: string;
  /** 透传给 BaseLayout：文章分类名 */
  section?: string;
}

const {
  title,
  description,
  eyebrow,
  pageTitle,
  pageDescription,
  count,
  category,
  activeTag,
  headings,
  ogType,
  publishedTime,
  section,
} = Astro.props;

// 兜底：props 没传时从 URL 推断（兼容 /tags/[tag]/ 与裸路径访问）
const BASE = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');
const pathname = Astro.url.pathname.replace(BASE, '/').replace(/\/+$/, '') || '/';
const segs = pathname.split('/').filter(Boolean);

let layoutCat: CategorySlug | undefined = category;
let layoutActive: string | undefined = activeTag;

if (!layoutCat) {
  if (segs[0] === 'blog' && segs[1]) {
    layoutCat = getCategory(segs[1] as CategorySlug)?.slug;
  } else if (segs[0] === 'tags' && segs[1]) {
    const sub = getSubcategory(segs[1]);
    if (sub) layoutCat = sub.category;
  }
}
const hasSidebar = !!layoutCat;
const hasToc = !!headings && headings.some((h) => h.depth === 2);
---

<BaseLayout
  title={title}
  description={description}
  ogType={ogType}
  publishedTime={publishedTime}
  section={section}
>
  <div
    class:list={[
      'blog-layout',
      { 'has-sidebar': hasSidebar, 'has-toc': hasToc },
    ]}
  >
    {hasSidebar && (
      <Sidebar category={layoutCat} activeTag={layoutActive} />
    )}
    <div class="blog-layout__main">
      {(pageTitle || eyebrow) && (
        <PageHeader
          eyebrow={eyebrow}
          title={pageTitle ?? ''}
          description={pageDescription}
          count={count}
        />
      )}
      <slot />
    </div>
    {hasToc && <TableOfContents headings={headings!} />}
  </div>
</BaseLayout>

<style>
  .blog-layout {
    display: grid;
    /* 默认两列：左目录 + 主内容 */
    grid-template-columns: 240px minmax(0, 1fr);
    column-gap: 4rem;
    padding: 2.5rem var(--page-pad-x);
  }
  /* 没有侧栏时（如 /blog/）塌缩为单列，主区撑满 */
  .blog-layout:not(.has-sidebar) {
    grid-template-columns: minmax(0, 1fr);
  }
  /* 文章页：有 TOC 时升级为三列布局 */
  .blog-layout.has-sidebar.has-toc {
    grid-template-columns: 240px minmax(0, 1fr) 200px;
  }
  .blog-layout__main {
    min-width: 0; /* 防止 grid 子项溢出 */
    width: 100%;
  }

  @media (max-width: 1280px) {
    /* 右侧 TOC 在窄屏隐藏，列数回到两列 */
    .blog-layout.has-sidebar.has-toc {
      grid-template-columns: 240px minmax(0, 1fr);
    }
  }

  @media (max-width: 768px) {
    .blog-layout,
    .blog-layout.has-sidebar,
    .blog-layout.has-sidebar.has-toc,
    .blog-layout:not(.has-sidebar) {
      grid-template-columns: 1fr;
      column-gap: 0;
      row-gap: 1rem;
      padding-top: 1.5rem;
    }
    .blog-layout__main {
      max-width: none;
    }
  }
</style>
