---
import {
  subcategories,
  getCategory,
  getSubcategory,
  type CategorySlug,
} from '../data/posts';
import { getCollection } from 'astro:content';

interface Props {
  /** 当前一级分类；不传则从 URL 推断 */
  category?: CategorySlug;
  /** 当前激活的二级 tag；其抽屉自动展开 */
  activeTag?: string;
}

const { category: propCategory, activeTag: propActiveTag } = Astro.props;

// 从 URL 反推当前分类（兼容 /blog/[cat]/ 与 /tags/[tag]/ 两种入口）
const pathname = Astro.url.pathname.replace(/\/+$/, '') || '/';
const segments = pathname.split('/').filter(Boolean);

let detectedCategory: CategorySlug | undefined = propCategory;
let detectedActiveTag: string | undefined = propActiveTag;

if (!detectedCategory) {
  if (segments[0] === 'blog' && segments[1]) {
    detectedCategory = getCategory(segments[1] as CategorySlug)?.slug;
  } else if (segments[0] === 'tags' && segments[1]) {
    const sub = getSubcategory(segments[1]);
    if (sub) detectedCategory = sub.category;
  }
}
if (!detectedActiveTag) {
  if (segments[0] === 'blog' && segments[2]) {
    // /blog/[cat]/[slug]/ —— 不强求匹配 subcategory.slug
    detectedActiveTag = segments[2];
  } else if (segments[0] === 'tags' && segments[1]) {
    detectedActiveTag = segments[1];
  }
}

const category = detectedCategory;
const activeTag = detectedActiveTag;

// 每个 tag 对应的文章列表
const allPosts = category ? await getCollection(
  'posts',
  p => p.data.category === category
) : [];

function postsOf(cat: CategorySlug, tag: string) {
  return allPosts.filter(p => p.data.tags.includes(tag));
}
---

{category && (() => {
  const drawers = subcategories[category]
    .map(sub => {
      const list = postsOf(category, sub.slug);
      const isOpen = activeTag === sub.slug;
      return { sub, list, isOpen };
    })
    .filter(d => d.list.length > 0 || d.isOpen);
  if (drawers.length === 0) return null;
  return (
    <aside class="sidebar">
      <nav class="sidebar__nav" aria-label="二级目录">
        {drawers.map(({ sub, list, isOpen }) => (
          <details class="drawer" open={isOpen || undefined}>
            <summary class="drawer__head">
              <span class="drawer__label">{sub.label}</span>
              {list.length > 0 && (
                <span class="drawer__count mono">{list.length}</span>
              )}
              <span class="drawer__caret" aria-hidden="true"></span>
            </summary>
            {list.length > 0 && (
              <ul class="drawer__list">
                {list.map(post => {
                  const slug = post.id.split('/').pop()!.replace(/\.md$/, '');
                  return (
                    <li>
                      <a
                        href={`/blog/${category}/${slug}/`}
                        class:list={[
                          'drawer__item',
                          { 'is-active': segments[2] === slug }
                        ]}
                      >{post.data.title}</a>
                    </li>
                  );
                })}
              </ul>
            )}
          </details>
        ))}
      </nav>
    </aside>
  );
})()}

<style>
  .sidebar {
    position: sticky;
    top: calc(var(--nav-h) + 1.5rem);
    align-self: start;
  }
  .sidebar__nav {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  /* ── 抽屉（drawer） ───────────────────────────── */
  .drawer { margin: 0; }
  .drawer__head {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.5rem 0;
    color: var(--text);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    user-select: none;
    transition: color 120ms ease;
  }
  .drawer__head::-webkit-details-marker { display: none; }
  .drawer__head:hover { color: var(--accent); }

  .drawer__label { flex: 1 1 auto; }
  .drawer__count {
    font-size: 0.6875rem;
    color: var(--text-mute);
  }
  .drawer__caret {
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid var(--text-mute);
    transition: transform 180ms ease;
    flex-shrink: 0;
    position: relative;
    top: 2px;
  }
  .drawer[open] > .drawer__head { color: var(--accent); }
  .drawer[open] .drawer__caret { transform: rotate(180deg); }

  .drawer__list {
    list-style: none;
    margin: 0.25rem 0 0.75rem 0;
    padding: 0 0 0 0.85rem;
    border-left: 1px solid var(--ink-line);
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .drawer__item {
    display: block;
    padding: 0.2rem 0 0.2rem 0.6rem;
    color: var(--text-mute);
    font-size: 0.875rem;
    line-height: 1.45;
    transition: color 120ms ease, padding-left 180ms ease;
  }
  .drawer__item:hover {
    color: var(--text);
    padding-left: 0.85rem;
  }
  .drawer__item.is-active { color: var(--accent); }

  @media (max-width: 768px) {
    .sidebar {
      position: static;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--ink-line);
      margin-bottom: 1rem;
    }
  }
</style>